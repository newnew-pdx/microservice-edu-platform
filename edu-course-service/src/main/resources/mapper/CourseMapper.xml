<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.dyl.edu.course.mapper.CourseMapper">

    <resultMap id="courseResultMap" type="CourseEntity">
        <id property="id" column="id"/>
        <result property="title" column="title"/>
        <result property="description" column="description"/>
        <result property="price" column="price"/>
        <result property="status" column="status"/>
        <result property="teacherName" column="teacher_name"/>
        <result property="coverUrl" column="cover_url"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
        <result property="deleted" column="deleted"/>
    </resultMap>

    <sql id="courseColumns">
        id, title, description, price, status, teacher_name, cover_url,
        created_at, updated_at, deleted
    </sql>

    <!-- 按 ID 查询时排除逻辑删除数据。 -->
    <select id="selectById" resultMap="courseResultMap">
        SELECT <include refid="courseColumns"/>
        FROM course
        WHERE id = #{courseId}
          AND deleted = 0
    </select>

    <!-- 课程列表只展示已上线且未删除的数据。 -->
    <select id="selectOnlineList" resultMap="courseResultMap">
        SELECT <include refid="courseColumns"/>
        FROM course
        WHERE status = 'ONLINE'
          AND deleted = 0
        ORDER BY id ASC
    </select>
</mapper>
