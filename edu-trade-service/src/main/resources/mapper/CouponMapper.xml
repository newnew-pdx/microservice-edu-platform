<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.dyl.edu.trade.mapper.CouponMapper">

    <resultMap id="couponResultMap" type="CouponEntity">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="totalStock" column="total_stock"/>
        <result property="stock" column="stock"/>
        <result property="amount" column="amount"/>
        <result property="status" column="status"/>
        <result property="startTime" column="start_time"/>
        <result property="endTime" column="end_time"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
        <result property="deleted" column="deleted"/>
    </resultMap>

    <!-- 领取前查询未删除的优惠券基础信息。 -->
    <select id="selectById" resultMap="couponResultMap">
        SELECT id, name, total_stock, stock, amount, status,
               start_time, end_time, created_at, updated_at, deleted
        FROM coupon
        WHERE id = #{couponId}
          AND deleted = 0
    </select>
</mapper>
